{
  "manifest_version": 3,
  "name": "PDF Studio - Pure Local PDF Tool",
  "version": "1.0.0",
  "description": "全本地、全功能 PDF 工作台 — 合并、拆分、编辑、签名、解密",
  "permissions": ["storage", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "打开 PDF 工作台"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
